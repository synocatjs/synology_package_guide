#!/bin/bash

### Use PKG_DIR as working directory.
PKG_DIR=/tmp/_test_spk
rm -rf $PKG_DIR
mkdir -p $PKG_DIR

### get spk packing functions
source /pkgscripts/include/pkg_util.sh

create_package_tgz() {
    local package_tgz_dir=/tmp/_package_tgz
    local binary_dir=$package_tgz_dir/usr/local/bin

    ### clear destination directory
    rm -rf $package_tgz_dir && mkdir -p $package_tgz_dir

    ### install demo binary
    mkdir -p $binary_dir
    
    if [ -f /source/basic/demo ]; then
        cp -av /source/basic/demo $binary_dir/
        echo "Copied demo binary"
    else
        echo "Error: basic demo binary not found!"
        exit 1
    fi

    ### create package.tgz
    pkg_make_package $package_tgz_dir "${PKG_DIR}"
}

create_spk(){
    local source_dir="/source/basic"
    
    echo "Creating INFO file..."
    
    # 生成 INFO 文件
    if [ -f $source_dir/INFO.sh ]; then
        (cd $source_dir && ./INFO.sh) > $PKG_DIR/INFO
        echo "INFO file generated"
    else
        echo "Error: INFO.sh not found at $source_dir/INFO.sh"
        exit 1
    fi
    
    # 复制 scripts 目录（注意路径）
    if [ -d $source_dir/scripts ]; then
        cp -av $source_dir/scripts $PKG_DIR/
        echo "Copied scripts"
    fi
    
    # 复制图标
    for icon in $source_dir/PACKAGE_ICON*.PNG; do
        if [ -f "$icon" ]; then
            cp -av "$icon" $PKG_DIR/
            echo "Copied icon: $(basename $icon)"
        fi
    done
    
    # 复制 conf 目录
    if [ -d $source_dir/conf ]; then
        cp -av $source_dir/conf $PKG_DIR/
        echo "Copied conf"
    fi

    ### Create the final spk
    mkdir -p /image/packages
    echo "Creating SPK package..."
    pkg_make_spk ${PKG_DIR} "/image/packages" $(pkg_get_spk_family_name)
    echo "SPK created successfully"
}

main() {
    create_package_tgz
    create_spk
}

main "$@"